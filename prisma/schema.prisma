generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sport {
  EPL
  NFL
  MLB
  NBA
  NHL
  NCAAF
  NCAAB
  WORLD_CUP
  PGA
  LIV
  MLSNEXT
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

enum ParlayStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

enum GamePickResult {
  PENDING
  WON
  LOST
  PUSH
}

enum TournamentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String   @map("password_hash")
  walletBalance Int      @default(1000) @map("wallet_balance")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  isAdmin Boolean @default(false) @map("is_admin")

  leaderboardScore      LeaderboardScore?
  parlays               Parlay[]
  tournamentsCreated    Tournament[]
  tournamentMemberships TournamentMember[]
  bracketEntries        BracketEntry[]
  passwordResetTokens   PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LeaderboardScore {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  cumulativeScore Int      @default(0) @map("cumulative_score")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cumulativeScore(sort: Desc)])
  @@map("leaderboard_scores")
}

model Game {
  id             String     @id @default(cuid())
  externalId     String     @unique @map("external_id")
  sport          Sport
  league         String
  homeTeam       String     @map("home_team")
  awayTeam       String     @map("away_team")
  homeTeamBadge  String?    @map("home_team_badge")
  awayTeamBadge  String?    @map("away_team_badge")
  scheduledStart DateTime   @map("scheduled_start")
  homeScore      Int?       @map("home_score")
  awayScore      Int?       @map("away_score")
  status         GameStatus @default(SCHEDULED)
  round          Int?
  season         String?
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  parlayGames ParlayGame[]

  @@index([sport, scheduledStart])
  @@index([status])
  @@map("games")
}

model Parlay {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  betAmount  Int          @map("bet_amount")
  numGames   Int          @map("num_games")
  multiplier Float
  status     ParlayStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parlayGames ParlayGame[]
  result      ParlayResult?

  @@index([userId, status])
  @@index([status])
  @@map("parlays")
}

model ParlayGame {
  id         String         @id @default(cuid())
  parlayId   String         @map("parlay_id")
  gameId     String         @map("game_id")
  pickedTeam String         @map("picked_team")
  result     GamePickResult @default(PENDING)

  parlay Parlay @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id])

  @@unique([parlayId, gameId])
  @@map("parlay_games")
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  inviteCode  String           @unique @map("invite_code")
  createdById String           @map("created_by_id")
  startDate   DateTime         @map("start_date")
  endDate     DateTime         @map("end_date")
  status      TournamentStatus @default(ACTIVE)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  createdBy User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members   TournamentMember[]
  sports    TournamentSport[]

  @@index([createdById])
  @@index([inviteCode])
  @@map("tournaments")
}

model TournamentMember {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  userId       String   @map("user_id")
  joinedAt     DateTime @default(now()) @map("joined_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId])
  @@map("tournament_members")
}

model TournamentSport {
  id           String @id @default(cuid())
  tournamentId String @map("tournament_id")
  sport        Sport

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, sport])
  @@map("tournament_sports")
}

model BracketChallenge {
  id          String   @id @default(cuid())
  name        String
  description String?
  sport       Sport
  lockTime    DateTime @map("lock_time")
  createdAt   DateTime @default(now()) @map("created_at")

  entries BracketEntry[]
  results BracketResult[]

  @@map("bracket_challenges")
}

model BracketResult {
  id          String   @id @default(cuid())
  challengeId String   @map("challenge_id")
  round       String   // "group" | "group2" | "qf" | "sf" | "final"
  key         String   // group: "A".."H"; qf: "1".."4"; sf: "1".."2"; final: "1"
  winner      String
  source      String   @default("manual") // "scraper" | "manual"
  updatedAt   DateTime @updatedAt @map("updated_at")

  challenge BracketChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, round, key])
  @@map("bracket_results")
}

model BracketEntry {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  picks       Json     @default("{}")
  score       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge BracketChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([challengeId, score(sort: Desc)])
  @@map("bracket_entries")
}

model ParlayResult {
  id                    String   @id @default(cuid())
  parlayId              String   @unique @map("parlay_id")
  payoutAmount          Int      @map("payout_amount")
  leaderboardAdjustment Int      @map("leaderboard_adjustment")
  walletAdjustment      Int      @map("wallet_adjustment")
  createdAt             DateTime @default(now()) @map("created_at")

  parlay Parlay @relation(fields: [parlayId], references: [id], onDelete: Cascade)

  @@map("parlay_results")
}
